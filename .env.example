# Copy this file to .env on the server. Never commit the real .env file.
MEPPP_ENV=production
MEPPP_SECRET_KEY=replace-with-a-long-random-value
MEPPP_SECRET_KEY_FALLBACKS=
MEPPP_ALLOWED_HOSTS=meppp.com,www.meppp.com
MEPPP_CSRF_TRUSTED_ORIGINS=https://meppp.com,https://www.meppp.com
MEPPP_DEBUG=0
MEPPP_SECURE=1
MEPPP_SECURE_HSTS_SECONDS=3600
MEPPP_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
MEPPP_SECURE_HSTS_PRELOAD=0
MEPPP_TRUST_PROXY=1
# The fixed Compose gateway is the only proxy allowed to supply forwarded headers.
# If the subnet must change after collision preflight, update all four values together.
MEPPP_TRUSTED_PROXY_IPS=172.30.89.1/32
MEPPP_TIME_ZONE=Asia/Shanghai
MEPPP_LOG_LEVEL=INFO
MEPPP_MEDIA_MIN_FREE_BYTES=268435456
MEPPP_MEDIA_MAX_TOTAL_BYTES=21474836480
MEPPP_MEMBER_DAILY_MEDIA_BYTES=104857600
MEPPP_MEMBER_PENDING_ENTRY_LIMIT=5
MEPPP_HEALTHCHECK_HOST=meppp.com

# The app remains reachable only through this host loopback port.
MEPPP_PORT=18080
MEPPP_IMAGE=meppp:v0.1.0-rc.7
MEPPP_NETWORK_NAME=meppp_internal
MEPPP_NETWORK_SUBNET=172.30.89.0/28
MEPPP_NETWORK_GATEWAY=172.30.89.1
MEPPP_CONTAINER_IP=172.30.89.10

# Production uses an explicit host path so backups and recovery remain visible
# to the operator. It must be local storage owned by 10001:10001.
MEPPP_DATA_MOUNT=/srv/meppp/data
MEPPP_DATA_VOLUME_NAME=meppp_data

# Backups use SQLite's online backup API and a sha256 manifest. UTC daily and ISO
# weekly retention are enforced inside /data; copy them to independent storage too.
MEPPP_BACKUP_BEFORE_MIGRATE=1
MEPPP_BACKUP_DAILY=7
MEPPP_BACKUP_WEEKLY=4

# Single-process safety limits for the shared host.
MEPPP_CPUS=1.0
MEPPP_MEMORY_LIMIT=768m
MEPPP_MEMORY_RESERVATION=256m
MEPPP_TMPFS_SIZE=192m
MEPPP_PIDS_LIMIT=256
MEPPP_LOG_MAX_SIZE=10m
MEPPP_LOG_MAX_FILES=5
