# Shape only: do not install this example directly.
# Generate the real include from Cloudflare's current official network lists:
# python3 deploy/update_cloudflare_real_ip.py \
#   /www/server/nginx/conf/meppp-cloudflare-real-ip.conf
#
# The generated file contains one `set_real_ip_from` per official Cloudflare
# network, followed by:
real_ip_header CF-Connecting-IP;
real_ip_recursive on;
