MEPPP_BACKUP_SOURCE=root@38.22.89.60
# The packaged systemd units grant write access only to this exact destination
# and lock directory. Review and update the units together before changing either.
MEPPP_BACKUP_DESTINATION=/srv/backups/meppp.com
MEPPP_BACKUP_MAX_AGE_SECONDS=93600
MEPPP_BACKUP_MINIMUM_FREE_KIB=10485760
MEPPP_BACKUP_LOCK_DIR=/run/meppp-remote-pull/lock
